{
  "appId": "com.arms.mobile",
  "appName": "ARMS",
  "webDir": "out",
  "server": {
    "url": "https://arms-opal.vercel.app/portal",
    "androidScheme": "https",
    "allowNavigation": [
      "arms-opal.vercel.app",
      "enlqpifpxuecxxozyiak.supabase.co"
    ]
  },
  "android": {
    "backgroundColor": "#4f46e5",
    "allowMixedContent": false,
    "captureInput": true,
    "buildOptions": {
      "keystorePath": "",
      "keystoreAlias": "",
      "keystorePassword": "",
      "signingType": "apksigner"
    }
  },
  "plugins": {
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#4f46e5"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#4f46e5",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": true,
      "spinnerColor": "#ffffff"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
